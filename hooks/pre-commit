#!/bin/sh
# ─────────────────────────────────────────────────────────────────────────────
# Lattice-Shield Pre-Commit Hook (standalone / manual install)
# Copy to: .git/hooks/pre-commit   chmod +x .git/hooks/pre-commit
#
# Or let Lattice-Shield install it for you:
#   lattice-shield install-hook
# ─────────────────────────────────────────────────────────────────────────────

# Get staged files (adds, copies, modifications, renames — skip deletes)
STAGED=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED" ]; then
  exit 0
fi

# Verify lattice-shield is on PATH
if ! command -v lattice-shield >/dev/null 2>&1; then
  echo ""
  echo "  [Lattice-Shield] WARNING: 'lattice-shield' not found on PATH."
  echo "  Install it with: go install github.com/lattice-suite/lattice-shield@latest"
  echo ""
  # Allow the commit to proceed so teams aren't blocked during initial rollout.
  exit 0
fi

echo ""
echo "  Running Lattice-Shield security check..."
echo ""

# shellcheck disable=SC2086
lattice-shield check $STAGED
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
  echo ""
  echo "  ╔══════════════════════════════════════════════════════════╗"
  echo "  ║  COMMIT BLOCKED by Lattice-Shield                        ║"
  echo "  ║  Secrets or API keys were detected in staged files.      ║"
  echo "  ║  Run: lattice-shield anonymize <file>  to sanitize.      ║"
  echo "  ╚══════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

exit 0
